# Server
SERVER_PORT=8080
REQUEST_TIMEOUT=30s

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=product_management
DB_SSLMODE=disable

# Connection pool (tune against PostgreSQL max_connections and app instance count)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m
