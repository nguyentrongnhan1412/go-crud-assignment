{
  "info": {
    "_postman_id": "bca7f615-386b-4ad7-ae68-af9ab0c4c237",
    "name": "Product Management API",
    "description": "REST API collection for the Product Management service.\n\nDefault base URL: http://localhost:8080\n\nImport this collection into Postman, then optionally import the environment file `Product-Management-API.postman_environment.json` from the same folder.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "28373262"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Returns API health status."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const product = pm.response.json();",
                  "    pm.collectionVariables.set('productId', product.id);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Keychron K8 Pro Wireless Mechanical Keyboard\",\n  \"description\": \"87-key tenkeyless mechanical keyboard with hot-swappable Gateron Brown switches, RGB backlighting, Bluetooth 5.1, USB-C wired mode, and macOS/Windows compatibility.\",\n  \"price\": 129.99,\n  \"quantity\": 25\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            },
            "description": "Creates a new product. On success, saves the returned `id` to the `productId` collection variable."
          },
          "response": []
        },
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            },
            "description": "Returns a list of all products."
          },
          "response": []
        },
        {
          "name": "Search Products by Keyword",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?keyword=keyboard",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "keyword",
                  "value": "keyboard",
                  "description": "Search in product name and description"
                }
              ]
            },
            "description": "Returns products matching the keyword in name or description."
          },
          "response": []
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/:productId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                ":productId"
              ],
              "variable": [
                {
                  "key": "productId",
                  "value": "2"
                }
              ]
            },
            "description": "Returns a single product by ID."
          },
          "response": []
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Keychron K8 Pro Wireless Mechanical Keyboard\",\n  \"description\": \"87-key tenkeyless mechanical keyboard.\",\n  \"price\": 100.50,\n  \"quantity\": 20\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/:productId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                ":productId"
              ],
              "variable": [
                {
                  "key": "productId",
                  "value": "4"
                }
              ]
            },
            "description": "Updates an existing product by ID."
          },
          "response": []
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/:productId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                ":productId"
              ],
              "variable": [
                {
                  "key": "productId",
                  "value": "4"
                }
              ]
            },
            "description": "Deletes a product by ID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Validation Examples",
      "item": [
        {
          "name": "Create Product - Missing Name",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"description\": \"No name provided\",\n  \"price\": 10,\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            },
            "description": "Expected: 400 Bad Request\n{ \"message\": \"name is required\" }"
          },
          "response": []
        },
        {
          "name": "Create Product - Invalid Price",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Product\",\n  \"description\": \"Invalid price\",\n  \"price\": 0,\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            },
            "description": "Expected: 400 Bad Request\n{ \"message\": \"price must be greater than 0\" }"
          },
          "response": []
        },
        {
          "name": "Get Product - Not Found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/99999",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "99999"
              ]
            },
            "description": "Expected: 404 Not Found\n{ \"message\": \"product not found\" }"
          },
          "response": []
        },
        {
          "name": "Get Product - Invalid ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/abc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "abc"
              ]
            },
            "description": "Expected: 400 Bad Request\n{ \"message\": \"invalid product id\" }"
          },
          "response": []
        }
      ]
    }
  ],
